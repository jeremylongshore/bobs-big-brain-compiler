# ===== Node.js =====

# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Framework-specific
.next/
.nuxt/

# Testing / coverage
coverage/
.nyc_output/

# Mutation testing (Stryker)
.stryker-tmp/
reports/mutation/

# Dog-food workspaces. The skill writes sanitized per-run summaries
# into dogfood/runs/<run-id>/ (kept) but never copies the actual
# compiled wiki or raw answer content here — those live in
# ~/.cache/ico-your-internals/ outside the repo. This guard is
# belt-and-suspenders in case a workspace ever gets moved here.
dogfood/runs/*/workspace/
dogfood/runs/*/receipts.jsonl
dogfood/runs/*/verifications.jsonl
dogfood/runs/*/cost.jsonl

# Python bytecode caches (the dog-food skill scripts are Python)
__pycache__/
*.pyc

# TypeScript
*.tsbuildinfo

# Linting
.eslintcache

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== OS =====
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# ===== IDE =====
.idea/
.vscode/
*.code-workspace

# ===== Environment =====
.env
.env.local
.env.*.local

# ===== Workspace =====
workspace/raw/
workspace/tasks/
workspace/outputs/
workspace/recall/
workspace/audit/

# ===== SQLite =====
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# ===== Beads =====
.beads/*.db-shm
.beads/*.db-wal

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/export-state.json

# ===== Local design-diagram skill output =====
.arch/

# ===== npm pack output (verify-npm-pack.sh) =====
packages/cli/intentional-cognition-os-*.tgz
packages/cli/README.md
packages/cli/LICENSE
