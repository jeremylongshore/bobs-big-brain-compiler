# Intentional Cognition OS — Environment Configuration
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# LLM provider (the compiler is model-agnostic)
# ---------------------------------------------------------------------------
# Pick a backend with ICO_PROVIDER. Default is "anthropic" (Claude). Built-ins:
#   anthropic           — Claude (native Anthropic API)              [default]
#   openai              — OpenAI chat-completions
#   groq                — Groq (OpenAI-compatible, free tier)
#   nvidia              — NVIDIA NIM (OpenAI-compatible, free tier)
#   deepseek            — DeepSeek over its OpenAI-compatible endpoint
#   deepseek-anthropic  — DeepSeek over its Anthropic-compatible endpoint
#   local | ollama | vllm — a local OpenAI-compatible server (e.g. Ollama)
#   custom              — bring your own endpoint (see ICO_BASE_URL + ICO_PROVIDER_WIRE)
# ICO_PROVIDER=anthropic

# Each provider reads its own key env (below). You may instead set ICO_API_KEY
# once and it is used regardless of provider.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# NVIDIA_API_KEY=
# DEEPSEEK_API_KEY=
# ICO_API_KEY=               # generic fallback, wins over the provider-specific key

# Override the model and/or endpoint for any provider. ICO_MODEL defaults to the
# selected provider's default model; ICO_BASE_URL overrides its API base URL
# (handy for proxies or a local server). A local server may run keyless.
# ICO_MODEL=
# ICO_BASE_URL=

# custom provider only: declare the wire format + base URL of your endpoint.
#   ICO_PROVIDER_WIRE=openai      # or "anthropic"
#   ICO_BASE_URL=https://my-gateway.example/v1
#   ICO_API_KEY=...               # if your endpoint needs one

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------
# ICO_WORKSPACE=./workspace
# ICO_RESEARCH_MODEL=             # defaults to claude-opus-4-6 on anthropic, else ICO_MODEL
# ICO_LOG_LEVEL=info
