# Intentional Cognition OS — Environment Configuration
# Copy this file to .env and fill in your values.

# LLM provider — "anthropic" (default) or "deepseek".
# ICO_PROVIDER=anthropic

# Required for AI features (compilation, reasoning).
# For ICO_PROVIDER=anthropic, set ANTHROPIC_API_KEY; for deepseek, set DEEPSEEK_API_KEY.
ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# DeepSeek is OpenAI-compatible; override the endpoint/model if needed.
# Supported models: deepseek-v4-flash (default, fast) or deepseek-v4-pro.
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# Optional overrides
# ICO_WORKSPACE=./workspace
# ICO_MODEL=claude-sonnet-4-6        # provider-specific; for deepseek defaults to DEEPSEEK_MODEL
# ICO_RESEARCH_MODEL=claude-opus-4-6
# ICO_LOG_LEVEL=info
